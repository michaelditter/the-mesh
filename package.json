{
  "name": "the-mesh",
  "version": "1.0.0",
  "description": "Bridge a Meshtastic (LoRa) node to Nostr — off-grid mesh messages become permanent public records. The sermon/post layer from You Cannot Eat Code, made real.",
  "type": "module",
  "bin": { "the-mesh": "bridge.mjs" },
  "scripts": { "start": "node bridge.mjs" },
  "engines": { "node": ">=22" },
  "dependencies": {
    "@meshtastic/core": "^2.6.7",
    "@meshtastic/transport-http": "^0.2.5",
    "nostr-tools": "^2.7.0"
  },
  "optionalDependencies": {
    "@meshtastic/transport-node-serial": "^0.0.2"
  },
  "keywords": ["meshtastic", "lora", "nostr", "off-grid", "bridge", "youcannoteat"],
  "author": "Michael Ditter",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/michaelditter/the-mesh" }
}
